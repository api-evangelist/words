              }
            ]
          },
          "docs": "Returns the domain-usage examples of the given word."
        },
        {
          "info": {
            "name": "Get Word In Region",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/inRegion",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns the geographic regions where the given word is used."
        },
        {
          "info": {
            "name": "Get Word Region Of",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/regionOf",
            "params": [
              {
