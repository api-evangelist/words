        },
        {
          "info": {
            "name": "Get Word Entails",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/entails",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns words logically entailed by the given word, typically verbs."
        },
        {
          "info": {
            "name": "Get Word Member Of",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/memberOf",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
