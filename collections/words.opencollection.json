                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns the members that belong to the given group word."
        },
        {
          "info": {
            "name": "Get Word Substance Of",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/substanceOf",
            "params": [
