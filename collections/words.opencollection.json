          },
          "docs": "Returns materials of which the given word is a substance."
        },
        {
          "info": {
            "name": "Get Word Has Substances",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/hasSubstances",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns the substances that compose the given word."
        }
      ]
    },
    {
      "info": {
        "name": "Categories",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Word In Category",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/inCategory",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns the categories the given word belongs to."
        },
        {
          "info": {
            "name": "Get Word Has Categories",
            "type": "http"
          },
          "http": {
            "method": "GET",
