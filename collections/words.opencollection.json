            "name": "Get Word Instances",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/instances",
            "params": [
              {
                "name": "word",
                "value": "apple",
                "type": "path",
                "description": "The English word to look up."
              }
            ]
          },
          "docs": "Returns specific instances of the given word (e.g. concrete examples of a category)."
        },
        {
          "info": {
            "name": "Get Word Instance Of",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/instanceOf",
            "params": [
              {
                "name": "word",
