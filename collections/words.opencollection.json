        },
        {
          "info": {
            "name": "Get Word Has Members",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://wordsapiv1.p.rapidapi.com/words/:word/hasMembers",
            "params": [
              {
                "name": "word",
