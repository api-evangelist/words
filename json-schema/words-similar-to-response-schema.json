{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/words/refs/heads/main/json-schema/words-similar-to-response-schema.json",
  "title": "SimilarToResponse",
  "description": "SimilarToResponse schema from Words API",
  "type": "object",
  "properties": {
    "word": {
      "type": "string",
      "example": "bright"
    },
    "similarTo": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "vivid",
        "brilliant"
      ]
    }
  }
}