{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/words/refs/heads/main/json-structure/words-has-types-response-structure.json",
  "name": "HasTypesResponse",
  "description": "HasTypesResponse schema from Words API",
  "type": "object",
  "properties": {
    "word": {
      "type": "string",
      "example": "fruit"
    },
    "hasTypes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "apple",
        "orange",
        "pear"
      ]
    }
  }
}