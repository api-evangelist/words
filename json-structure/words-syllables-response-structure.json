{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/words/refs/heads/main/json-structure/words-syllables-response-structure.json",
  "name": "SyllablesResponse",
  "description": "Response from GET /words/{word}/syllables.",
  "type": "object",
  "properties": {
    "word": {
      "type": "string",
      "example": "apple"
    },
    "numSyllables": {
      "type": "int32",
      "example": 2
    },
    "list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "ap",
        "ple"
      ]
    }
  }
}